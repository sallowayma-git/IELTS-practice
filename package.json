{
  "name": "ielts-practice",
  "version": "0.0.1-beta",
  "description": "IELTS Practice Application",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "prepare:writing": "npm --prefix apps/writing-vue install --no-fund --no-audit",
    "build:writing": "npm run prepare:writing && npm --prefix apps/writing-vue run build",
    "start": "npm run build:writing && electron .",
    "start:electron": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "release:build": "node scripts/release-shell-build.mjs",
    "release:publish": "node scripts/release-shell-build.mjs --publish-on-tag",
    "build:resource-release": "node scripts/build-resource-release.mjs",
    "check:update-syntax": "node scripts/check-update-syntax.mjs",
    "verify:release-client-smoke": "node developer/tests/update/release-client-smoke.cjs",
    "verify:resource-release": "node scripts/verify-resource-release.mjs",
    "verify:resource-release-smoke": "node developer/tests/update/resource-release-smoke.mjs",
    "verify:shell-release": "node scripts/verify-shell-release.mjs",
    "verify:shell-release-smoke": "node developer/tests/update/shell-release-smoke.mjs",
    "verify:shell-support-smoke": "node developer/tests/update/shell-support-smoke.cjs",
    "verify:update-runtime": "node developer/tests/update/renderer-ready-smoke.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sallowayma-git/IELTS-practice.git"
  },
  "build": {
    "appId": "com.sallowayma.ieltspractice",
    "productName": "IELTS Practice",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "zh-CN",
      "zh-TW"
    ],
    "directories": {
      "output": "dist/electron"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "files": [
      "electron/**/*",
      "dist/writing/**/*",
      "index.html",
      "css/**/*",
      "js/**/*",
      "templates/exam-placeholder.html",
      "templates/template_base.html",
      "templates/question-types.js",
      "assets/data/**/*",
      "assets/generated/**/*",
      "assets/wordlists/**/*",
      "assets/images/**/*",
      "assets/scripts/*.js",
      "!assets/images/app-icon.icns",
      "!assets/images/app-icon.ico",
      "!templates/ci-practice-fixtures/**",
      "!assets/scripts/*.py",
      "!electron/test_*.js",
      "!electron/test-*.js",
      "!node_modules/better-sqlite3/deps/**",
      "!node_modules/better-sqlite3/src/**",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md",
      "!node_modules/**/*.markdown",
      "!node_modules/**/README*",
      "!node_modules/**/readme*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/CHANGES*",
      "!node_modules/**/HISTORY*",
      "!node_modules/**/AUTHORS*",
      "!node_modules/**/CONTRIBUTING*",
      "!node_modules/**/GOVERNANCE*",
      "!node_modules/**/SECURITY*",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/LICENCE*",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/doc/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/History*",
      "!node_modules/**/history*",
      "!node_modules/js-yaml/dist/**",
      "!node_modules/prebuild-install/**",
      "!node_modules/detect-libc/**",
      "!node_modules/expand-template/**",
      "!node_modules/github-from-package/**",
      "!node_modules/minimist/**",
      "!node_modules/mkdirp-classic/**",
      "!node_modules/napi-build-utils/**",
      "!node_modules/node-abi/**",
      "!node_modules/rc/**",
      "!node_modules/simple-get/**",
      "!node_modules/simple-concat/**",
      "!node_modules/tar-fs/**",
      "!node_modules/tar-stream/**",
      "!node_modules/tunnel-agent/**",
      "!**/.gitkeep",
      "!**/.DS_Store",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sallowayma-git",
        "repo": "IELTS-practice",
        "releaseType": "release"
      }
    ],
    "afterPack": "scripts/after-pack-prune-electron-locales.cjs",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.education",
      "icon": "assets/images/app-icon.icns",
      "artifactName": "ielts-practice-${version}-macos-${arch}.${ext}",
      "hardenedRuntime": true,
      "strictVerify": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "ielts-practice-${version}-macos-${arch}.${ext}",
      "title": "Install IELTS Practice",
      "iconSize": 128,
      "internetEnabled": false,
      "window": {
        "width": 700,
        "height": 430
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 360,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 140,
          "y": 330,
          "type": "file",
          "path": "assets/release/macos/mac-first-launch.command"
        },
        {
          "x": 360,
          "y": 330,
          "type": "file",
          "path": "assets/release/macos/mac-first-launch-guide.txt"
        }
      ]
    },
    "win": {
      "icon": "assets/images/app-icon.ico",
      "artifactName": "ielts-practice-${version}-windows-${arch}-setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "selectPerMachineByDefault": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
