{
  "name": "ielts-practice",
  "version": "0.6.0",
  "description": "IELTS Practice Application",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "start:electron": "electron .",
    "release:build": "electron-builder --publish never",
    "release:publish": "electron-builder --publish onTag",
    "build:resource-release": "node scripts/build-resource-release.mjs",
    "check:update-syntax": "node scripts/check-update-syntax.mjs",
    "verify:release-client-smoke": "node developer/tests/update/release-client-smoke.cjs",
    "verify:resource-release": "node scripts/verify-resource-release.mjs",
    "verify:resource-release-smoke": "node developer/tests/update/resource-release-smoke.mjs",
    "verify:shell-release": "node scripts/verify-shell-release.mjs",
    "verify:shell-release-smoke": "node developer/tests/update/shell-release-smoke.mjs",
    "verify:shell-support-smoke": "node developer/tests/update/shell-support-smoke.cjs",
    "verify:update-runtime": "node developer/tests/update/renderer-ready-smoke.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sallowayma-git/IELTS-practice.git"
  },
  "build": {
    "appId": "com.sallowayma.ieltspractice",
    "productName": "IELTS Practice",
    "directories": {
      "output": "dist/electron"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "css/**/*",
      "js/**/*",
      "templates/**/*",
      "assets/**/*",
      "ListeningPractice/**/*",
      "README.md",
      "LICENSE",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sallowayma-git",
        "repo": "IELTS-practice",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "artifactName": "ielts-practice-${version}-macos-${arch}.${ext}",
      "hardenedRuntime": true,
      "strictVerify": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "ielts-practice-${version}-macos-${arch}.${ext}",
      "title": "Install IELTS Practice",
      "iconSize": 128,
      "internetEnabled": false,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 150,
          "y": 190,
          "type": "file"
        },
        {
          "x": 390,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "artifactName": "ielts-practice-${version}-windows-${arch}-setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "selectPerMachineByDefault": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.3.9",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
