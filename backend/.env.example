DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ielts_practice
SESSION_SECRET=replace-with-a-long-random-session-secret
PORT=3000
HOST=127.0.0.1
COOKIE_SECURE=false
TRUST_PROXY=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
TOTP_ENABLED=true
TOTP_ISSUER=IELTS Atlas
TOTP_ENCRYPTION_KEY=
ADMIN_RESET_TOTP=false
TRAFFIC_ENABLED=true
TOR_BRIDGES=
TOR_BRIDGES_FILE=/etc/tor/bridges.txt
SITE_HEALTH_BRIDGE_WARNING_THRESHOLD=3
