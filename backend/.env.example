POSTGRES_PASSWORD=replace-with-a-strong-local-postgres-password
DATABASE_URL=postgres://postgres:replace-with-a-strong-local-postgres-password@127.0.0.1:55432/ielts_practice
SESSION_SECRET=replace-with-a-long-random-session-secret
AUTH_HANDOFF_STATE_SECRET=
PORT=3000
HOST=127.0.0.1
COOKIE_SECURE=false
TRUST_PROXY=false
TRUSTED_PROXY_IPS=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
TOTP_ENABLED=true
TOTP_ISSUER=IELTS Atlas
TOTP_ENCRYPTION_KEY=
TOTP_VERIFICATION_MAX_AGE_MS=43200000
ADMIN_RESET_TOTP=false
TRAFFIC_ENABLED=true
TRAFFIC_SECRET=
AUTH_PUBLIC_URL=http://replace-with-auth-onion.onion
BUSINESS_PUBLIC_URL=http://replace-with-business-onion.onion
ADMIN_PUBLIC_URL=http://replace-with-admin-onion.onion
TOR_BRIDGES_FILE=/etc/tor/bridges.local.txt
# Default to the committed placeholder so copying this file does not require a
# plaintext bridge secret. Override to ./tor/bridges.local.txt only when you
# intentionally want to mount an unencrypted local bridge file.
TOR_BRIDGES_LOCAL_FILE=./tor/bridges.placeholder.txt
# TOR_BRIDGES_LOCAL_FILE=./tor/bridges.local.txt
TOR_BRIDGES_ENCRYPTED_FILE=
TOR_BRIDGES_AGE_IDENTITY_FILE=
TOR_BRIDGES_ENCRYPTED_LOCAL_FILE=./tor/bridges.age
TOR_BRIDGES_AGE_IDENTITY_LOCAL_FILE=./tor/bridge-age-identity.txt
SITE_HEALTH_BRIDGE_WARNING_THRESHOLD=3
